{
  "name": "waveguide-generator",
  "version": "1.1.0",
  "description": "Waveguide Generator: Interactive 3D visualization and optimization platform for acoustic waveguide design.",
  "license": "AGPL-3.0-or-later",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node scripts/start-all.js",
    "start:frontend": "node scripts/dev-server.js",
    "start:backend": "node scripts/run-backend-python.js --cwd server app.py",
    "dev": "node scripts/dev-server.js",
    "build": "webpack --mode production",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:server": "node scripts/run-backend-python.js --cwd server -m unittest discover -s tests",
    "lint": "eslint --config config/eslint.config.js src/",
    "format:check": "prettier --config config/prettier.config.json --ignore-path config/prettier.ignore --check src/",
    "bundle:check": "node scripts/check-bundle-size.js",
    "diag:payload": "node scripts/diagnostics/build-canonical-payload-from-reference.js",
    "diag:geometry": "node scripts/diagnostics/check-reference-horn-geometry-artifacts.js",
    "diag:mesher:reference-horn": "node scripts/run-backend-python.js scripts/diagnostics/build-occ-mesh-reference-horn.py",
    "diag:mesher:closed": "node scripts/run-backend-python.js scripts/diagnostics/check-occ-closed-mesh.py",
    "build:metal-helper": "node scripts/run-backend-python.js server/scripts/build_metal_native_release.py",
    "deps:bump-pins": "node scripts/run-backend-python.js scripts/bump_module_pins.py",
    "deps:check-pins": "node scripts/run-backend-python.js scripts/bump_module_pins.py --check",
    "preflight:backend": "node scripts/preflight-backend-runtime.js",
    "preflight:backend:strict": "node scripts/preflight-backend-runtime.js --strict",
    "doctor:backend": "node scripts/doctor-backend-runtime.js",
    "doctor:backend:json": "node scripts/doctor-backend-runtime.js --json",
    "doctor:backend:strict": "node scripts/doctor-backend-runtime.js --strict"
  },
  "keywords": [
    "3d",
    "visualization",
    "horn-design",
    "acoustics",
    "bem-solver"
  ],
  "author": "Magnus Andersen",
  "repository": {
    "type": "git",
    "url": "https://github.com/m3gnus/waveguide-generator.git"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  }
}
